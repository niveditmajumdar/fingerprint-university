# Fingerprint
FP_PUBLIC_KEY=your_public_key_here
FP_API_KEY=your_secret_api_key_here

# Sealed Client Results (base64 key from Dashboard > API Keys > Sealed Client Results)
# Keep INACTIVE in Dashboard until after you've deployed and tested the backend unseal.
# Then activate it in the Dashboard to start receiving sealed results from the JS agent.
FP_SEALED_KEY=your_base64_sealed_key_here

# Database
DATABASE_URL=postgresql://fp_user:yourpassword@localhost:5432/fp_university

# App
SESSION_SECRET=change_this_to_a_random_string
APP_URL=http://localhost:3000
